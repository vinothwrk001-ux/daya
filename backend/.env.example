NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/Daya_Creatives
MONGODB_ENABLE_LOCAL_FALLBACK=true
MONGODB_FALLBACK_URI=mongodb://127.0.0.1:27017/Daya_Creatives

# Public app URLs and CORS
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5173
INTERNAL_SERVICE_ORIGINS=
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

# Rate limiting
AUTH_RATE_LIMIT_MAX=60
API_RATE_LIMIT_MAX=5000

# Auth, cookies, and CSRF
JWT_ACCESS_SECRET=change_me_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_TTL_DAYS=30
JWT_SECRET=
JWT_ACCESS_COOKIE_MAX_AGE_MS=900000
AUTH_COOKIE_SAMESITE=lax
CSRF_SECRET=change_me_csrf_secret
CSRF_COOKIE_MAX_AGE_MS=7200000

# Staff auth
STAFF_JWT_ACCESS_SECRET=change_me_staff_access_secret
STAFF_JWT_REFRESH_SECRET=change_me_staff_refresh_secret
STAFF_JWT_ACCESS_EXPIRES_IN=15m
STAFF_JWT_REFRESH_EXPIRES_IN=30d
STAFF_JWT_REFRESH_TTL_DAYS=30

# Encryption
# Generate a strong 32+ character key for production.
ENCRYPTION_MASTER_KEY=generate_a_strong_32_plus_char_secret_here

# Uploads
MAX_FILE_SIZE_BYTES=5242880
MAX_VIDEO_FILE_SIZE_BYTES=52428800

# Cloudinary
# CLOUDINARY_URL can be used instead of the individual Cloudinary keys below.
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_WEBHOOK_MAX_AGE_SECONDS=600
RAZORPAY_DEFAULT_CURRENCY=INR
RAZORPAY_STARTUP_CHECK_AMOUNT=100
RAZORPAY_STARTUP_CHECK_TIMEOUT_MS=8000
RAZORPAY_HEALTH_ORDER_AMOUNT=100
RAZORPAY_HEALTH_TIMEOUT_MS=8000
RAZORPAY_PAYMENT_FETCH_TIMEOUT_MS=8000
RAZORPAY_TEST_CURRENCY=INR
RAZORPAY_TEST_AMOUNT=100

# Logistics and delivery
LOGISTICS_PROVIDER=SHIPROCKET
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_WEBHOOK_SECRET=
SHIPROCKET_PICKUP_LOCATION=Primary
PLATFORM_PICKUP_NAME=Primary
PLATFORM_PICKUP_PHONE=
PLATFORM_PICKUP_ADDRESS=
PLATFORM_PICKUP_ADDRESS_LINE1=
PLATFORM_PICKUP_ADDRESS_LINE2=
PLATFORM_PICKUP_CITY=
PLATFORM_PICKUP_STATE=
PLATFORM_PICKUP_PINCODE=
PLATFORM_PICKUP_COUNTRY=India
PLATFORM_PICKUP_LATITUDE=
PLATFORM_PICKUP_LONGITUDE=
SUPPORT_EMAIL=support@example.com

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_ORDER_SHIPPED_CONTENT_SID=

# Invoice and order documents
ORDER_SUPPORT_EMAIL=support@uchooseme.com
ORDER_SUPPORT_PHONE=+91 00000 00000
INVOICE_COMPANY_NAME=GRM Commerce
INVOICE_COMPANY_WEBSITE=www.uchooseme.com
INVOICE_TAX_LABEL=GST
INVOICE_TAX_ID=TAX-ID-PENDING

# Platform bootstrap and seed scripts
ALLOW_ADMIN_REGISTRATION=false
ADMIN_NAME=Platform Admin
ADMIN_PHONE=9999999999
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
PLATFORM_STORE_EMAIL=platform-store@grm.local
PLATFORM_STORE_PHONE=9000000000
PLATFORM_STORE_PASSWORD=PlatformStore123
BOOTSTRAP_EXECUTED_BY=cli
SERVER_ID=

# Runtime jobs and caches
PAYMENT_MAINTENANCE_CRON=*/15 * * * *
COMPANY_BRANDING_CACHE_MS=15000
REDIS_DISABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
